# dot-man environment variables
# Copy this file to .env and adjust values as needed

# Base directory for dot-man configuration (default: ~/.config/dot-man)
# DOT_MAN_DIR=~/.config/dot-man

# Path to the git repository (default: DOT_MAN_DIR/repo)
# DOT_MAN_REPO=~/.config/dot-man/repo

# Default editor for dot-man edit command (overrides $EDITOR)
# DOT_MAN_EDITOR=vim

# Disable shell completions auto-install (default: false)
# DOT_MAN_NO_COMPLETIONS=1

# Verbose logging (default: false)
# DOT_MAN_VERBOSE=1

# Age identity file for AGE encryption
# AGE_IDENTITY_FILE=~/.config/age/key.txt
